{
  "name": "burner-bouncer",
  "version": "1.0.0",
  "description": "Zero-dependency disposable/burner email detector",
  "keywords": ["email", "disposable", "burner", "spam", "validation"],
  "homepage": "https://github.com/grocerysushi/burner-bouncer#readme",
  "bugs": {"url": "https://github.com/grocerysushi/burner-bouncer/issues"},
  "repository": {"type": "git", "url": "git+https://github.com/grocerysushi/burner-bouncer.git"},
  "license": "MIT",
  "author": "",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
