{
  "name": "burner-bouncer",
  "version": "1.1.0",
  "description": "Zero-dependency disposable/burner email detector",
  "keywords": [
    "email",
    "disposable",
    "burner",
    "spam",
    "validation"
  ],
  "homepage": "https://github.com/grocerysushi/burner-bouncer#readme",
  "bugs": {
    "url": "https://github.com/grocerysushi/burner-bouncer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grocerysushi/burner-bouncer.git"
  },
  "license": "MIT",
  "author": "",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "burner-bouncer": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../scripts/gen-domains-ts.js && tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
